{
  "name": "valentine-backend",
  "version": "1.0.0",
  "description": "Backend for Valentine Date Planner — Node.js + Express + Prisma v7 + Neon DB",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
  "build": "prisma generate && tsc",
"start": "node --import tsx/esm dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.13.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.11",
    "cpy-cli": "^7.0.0",
    "prisma": "^7.4.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
