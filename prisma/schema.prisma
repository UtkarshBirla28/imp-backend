generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  image     String
  cuisine   String
  isCustom  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments DateAssignment[]

  @@map("restaurants")
}

model DateAssignment {
  id           String     @id @default(cuid())
  dateKey      String     @unique
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([dateKey])
  @@map("date_assignments")
}

model AppState {
  id               String   @id @default("singleton")
  proposalAccepted Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  @@map("app_state")
}

// ── NEW ───────────────────────────────────────────────────────────────────────
// isCustom = false → seeded defaults (protected from delete)
// isCustom = true  → added by user at runtime (can be deleted)
// sortOrder        → preserves order for defaults
model Promise {
  id        String   @id @default(cuid())
  text      String
  completed Boolean  @default(false)
  isCustom  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("promises")
}